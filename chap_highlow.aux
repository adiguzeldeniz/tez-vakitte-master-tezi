\newlabel{fig:ananum_compare}{{4.2}{20}{Comparing the analytical and the numerical solution for $\Omega $. The last slice of $|\Omega |^2$ is plotted for the basis set of values with a pulse area of $\mathcal {A} = 0.01\pi $. For the theoretical solution response function (\ref {responsefunction}) is used and (\ref {betazmax}) was used to calculate the theoretical b parameter. \relax }{figure.caption.9}{}}
\newlabel{fig:ananum_compare@cref}{{[figure][2][4]4.2}{[1][18][]20}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.3}{\ignorespaces Comparing the analytical and the numerical solution for $\rho _{eg}$. The last slice of $|\rho _{eg}|^2$ is plotted for the basis set of values with a pulse area of $\mathcal  {A} = 0.01\tmspace  +\thickmuskip {.2777em}\pi $. For the theoretical solution the calculated $\rho _{eg}(t)$ in (\ref {rhoegana}) is plotted. \relax }}{21}{figure.caption.10}\protected@file@percent }
\newlabel{fig:rhoegananum_compare}{{4.3}{21}{Comparing the analytical and the numerical solution for $\rho _{eg}$. The last slice of $|\rho _{eg}|^2$ is plotted for the basis set of values with a pulse area of $\mathcal {A} = 0.01\;\pi $. For the theoretical solution the calculated $\rho _{eg}(t)$ in (\ref {rhoegana}) is plotted. \relax }{figure.caption.10}{}}
\newlabel{fig:rhoegananum_compare@cref}{{[figure][3][4]4.3}{[1][20][]21}}
