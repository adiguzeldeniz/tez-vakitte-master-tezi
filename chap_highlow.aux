\@writefile{lof}{\contentsline {figure}{\numberline {4.19}{\ignorespaces $|\Omega |^2$ as a function of time and excitation, solved with two different methods. On the left side as a solution of ODE defined in \Cref  {burnham_2}, on the right side solved with Maxwell-Bloch equations where we used the basis set of values from \Cref  {table:the_parameters} and set the $\gamma =0$ to compare the results with \blx@tocontentsinit {0}\cite {BURNHAM1969}. Time scale on the right side is scaled for comparison with the left side, which is given in $\gamma $, with $\gamma = 141\, ns$ for $\alpha $-Iron.\relax }}{35}{figure.caption.26}\protected@file@percent }
\newlabel{fig:comparisonburnham}{{4.19}{35}{$|\Omega |^2$ as a function of time and excitation, solved with two different methods. On the left side as a solution of ODE defined in \Cref {burnham_2}, on the right side solved with Maxwell-Bloch equations where we used the basis set of values from \Cref {table:the_parameters} and set the $\gamma =0$ to compare the results with \cite {BURNHAM1969}. Time scale on the right side is scaled for comparison with the left side, which is given in $\gamma $, with $\gamma = 141\, ns$ for $\alpha $-Iron.\relax }{figure.caption.26}{}}
\newlabel{fig:comparisonburnham@cref}{{[figure][19][4]4.19}{[1][35][]35}}
