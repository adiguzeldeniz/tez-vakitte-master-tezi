\@writefile{toc}{\contentsline {subsection}{\numberline {4.3.1}$\Omega $ under the microscope}{28}{subsection.4.3.1}\protected@file@percent }
\newlabel{section_omegamicroscope}{{4.3.1}{28}{$\Omega $ under the microscope}{subsection.4.3.1}{}}
\newlabel{section_omegamicroscope@cref}{{[subsection][1][4,3]4.3.1}{[1][28][]28}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.12}{\ignorespaces $|\Omega |^2$ as a function of time and excitation, zoomed around the avoided crossings in \cref  {fig:Omega_highexc}. The crossing doesn't take place in a fixed pulse area but rather starts shifting gradually around population inversion by $\mathcal  {A} = \pi , 2\pi $. The white lines on the figure are plotted by $\mathcal  {A} = 1.024 \pi $ and $\mathcal  {A} = 2 \pi $ in the top and bottom graph, respectively. \relax }}{29}{figure.caption.19}\protected@file@percent }
\newlabel{fig:highres_zoom2block}{{4.12}{29}{$|\Omega |^2$ as a function of time and excitation, zoomed around the avoided crossings in \cref {fig:Omega_highexc}. The crossing doesn't take place in a fixed pulse area but rather starts shifting gradually around population inversion by $\mathcal {A} = \pi , 2\pi $. The white lines on the figure are plotted by $\mathcal {A} = 1.024 \pi $ and $\mathcal {A} = 2 \pi $ in the top and bottom graph, respectively. \relax }{figure.caption.19}{}}
\newlabel{fig:highres_zoom2block@cref}{{[figure][12][4]4.12}{[1][28][]29}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.13}{\ignorespaces $|\Omega |^2$ as a function of excitation and time, three slices 5,200 and 400 are plotted to observe the excitation shift by $\mathcal  {A} = \pi $. The avoided crossing gets shifted to minimally higher excitations by increasing target thickness. In the non propagating limit, we see the incoherent radiation, that is due to the full rotation of $\rho _{eg}$ in Bloch sphere, which doesn't generate coherently scattered light. \relax }}{30}{figure.caption.20}\protected@file@percent }
\newlabel{fig:Omega_highres_3block}{{4.13}{30}{$|\Omega |^2$ as a function of excitation and time, three slices 5,200 and 400 are plotted to observe the excitation shift by $\mathcal {A} = \pi $. The avoided crossing gets shifted to minimally higher excitations by increasing target thickness. In the non propagating limit, we see the incoherent radiation, that is due to the full rotation of $\rho _{eg}$ in Bloch sphere, which doesn't generate coherently scattered light. \relax }{figure.caption.20}{}}
\newlabel{fig:Omega_highres_3block@cref}{{[figure][13][4]4.13}{[1][29][]30}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3.2}Coherent radiation in thicker targets}{30}{subsection.4.3.2}\protected@file@percent }
