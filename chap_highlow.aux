\@writefile{lof}{\contentsline {figure}{\numberline {4.14}{\ignorespaces Coherent radiation $|\Omega |^2$ as a function of excitation and time. Maxwell-Bloch equations solved for different thicknesses: going from top left to bottom right, calculated for a thickness of $z_\mathrm  {max} = d = 0.25, 0.5,1,2,3,4\tmspace  +\thickmuskip {.2777em}\mu m$, correspondingly, with the conversion factor in \cref  {b_conversion} and using $b$ in \cref  {betazmax}. \relax }}{31}{figure.caption.21}\protected@file@percent }
\newlabel{fig:Omega_6block}{{4.14}{31}{Coherent radiation $|\Omega |^2$ as a function of excitation and time. Maxwell-Bloch equations solved for different thicknesses: going from top left to bottom right, calculated for a thickness of $z_\mathrm {max} = d = 0.25, 0.5,1,2,3,4\;\mu m$, correspondingly, with the conversion factor in \cref {b_conversion} and using $b$ in \cref {betazmax}. \relax }{figure.caption.21}{}}
\newlabel{fig:Omega_6block@cref}{{[figure][14][4]4.14}{[1][30][]31}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.15}{\ignorespaces $|\rho _{eg}|^2$ (left) and $\rho _{ee}$ (right) as a function of time and excitation. The Bessel beats from the $J_0$ can still be seen in $\rho _{eg}$, where they undergo a similar time shift and an avoided crossing. On the other hand, the structures which can be seen in \Cref  {fig:threeblock_rhoee} can no longer be seen in $\rho _{ee}$, as they wash out with increasing excitation. \relax }}{32}{figure.caption.22}\protected@file@percent }
\newlabel{fig:highres_rhoegrhoee}{{4.15}{32}{$|\rho _{eg}|^2$ (left) and $\rho _{ee}$ (right) as a function of time and excitation. The Bessel beats from the $J_0$ can still be seen in $\rho _{eg}$, where they undergo a similar time shift and an avoided crossing. On the other hand, the structures which can be seen in \Cref {fig:threeblock_rhoee} can no longer be seen in $\rho _{ee}$, as they wash out with increasing excitation. \relax }{figure.caption.22}{}}
\newlabel{fig:highres_rhoegrhoee@cref}{{[figure][15][4]4.15}{[1][30][]32}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.16}{\ignorespaces $\rho _{ee}$ as a function of slices and time, plotted for three different pulse areas $\mathcal  {A} = 0.01, 0.5, 0.88\tmspace  +\thickmuskip {.2777em}\pi $\relax }}{32}{figure.caption.23}\protected@file@percent }
\newlabel{fig:highres_rhoee_slices}{{4.16}{32}{$\rho _{ee}$ as a function of slices and time, plotted for three different pulse areas $\mathcal {A} = 0.01, 0.5, 0.88\;\pi $\relax }{figure.caption.23}{}}
\newlabel{fig:highres_rhoee_slices@cref}{{[figure][16][4]4.16}{[1][30][]32}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.17}{\ignorespaces Incoherent light $I_\mathrm  {inc}$ as a function of time and excitation on the left, 5 solutions with different pulse areas are plotted on the right side. \relax }}{33}{figure.caption.24}\protected@file@percent }
\newlabel{fig:summedrhoee_beyondler}{{4.17}{33}{Incoherent light $I_\mathrm {inc}$ as a function of time and excitation on the left, 5 solutions with different pulse areas are plotted on the right side. \relax }{figure.caption.24}{}}
\newlabel{fig:summedrhoee_beyondler@cref}{{[figure][17][4]4.17}{[1][33][]33}}
