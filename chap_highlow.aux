\@writefile{lof}{\contentsline {figure}{\numberline {4.6}{\ignorespaces The ratio $|\Omega |^2 / \rho _{ee}$ is plotted for different excitations, ranging from pulse area $\mathcal  {A} = 0\pi $ to $0.012 \pi $. The slices 5, 200, 400 are plotted out of the total number of slices $N = 400$. The colorbar shows the intensity in arbitrary units. \relax }}{23}{figure.caption.13}\protected@file@percent }
\newlabel{fig:lowexc_cohinc}{{4.6}{23}{The ratio $|\Omega |^2 / \rho _{ee}$ is plotted for different excitations, ranging from pulse area $\mathcal {A} = 0\pi $ to $0.012 \pi $. The slices 5, 200, 400 are plotted out of the total number of slices $N = 400$. The colorbar shows the intensity in arbitrary units. \relax }{figure.caption.13}{}}
\newlabel{fig:lowexc_cohinc@cref}{{[figure][6][4]4.6}{[1][23][]23}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.7}{\ignorespaces Top row: Ratio R(t) = $|\rho _{eg}|^2 / \rho _{ee}$, bottom row: Ratio $|\Omega |^2/ \rho _{ee}$, left column: thin target as in figure \ref {fig:lowexc_cohinc} left most plot, right column: thick target as in figure \ref {fig:lowexc_cohinc} right most plot. All curves are solutions with a pulse area $\mathcal  {A} = 0.011 \pi $, solved with the basis set of values in \Cref  {table:the_parameters}. Ratios are always plotted on the right y-scales, other quantities are plotted on the left y-scale respectively.\relax }}{24}{figure.caption.14}\protected@file@percent }
\newlabel{fig:4Block_ratio_cohinc}{{4.7}{24}{Top row: Ratio R(t) = $|\rho _{eg}|^2 / \rho _{ee}$, bottom row: Ratio $|\Omega |^2/ \rho _{ee}$, left column: thin target as in figure \ref {fig:lowexc_cohinc} left most plot, right column: thick target as in figure \ref {fig:lowexc_cohinc} right most plot. All curves are solutions with a pulse area $\mathcal {A} = 0.011 \pi $, solved with the basis set of values in \Cref {table:the_parameters}. Ratios are always plotted on the right y-scales, other quantities are plotted on the left y-scale respectively.\relax }{figure.caption.14}{}}
\newlabel{fig:4Block_ratio_cohinc@cref}{{[figure][7][4]4.7}{[1][23][]24}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.4}Summed incoherent radiation as an observable}{25}{subsection.4.2.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.8}{\ignorespaces Incoherent light, $\rho _{ee}$ averaged over all the slices. Left plotted for a low excitation regime and three lines plotted separately for different excitations on the right hand side. This quantity is the actual observable in an experiment, which is also called the $4\pi $ scattered light\relax }}{26}{figure.caption.15}\protected@file@percent }
\newlabel{fig:summed_rhoee}{{4.8}{26}{Incoherent light, $\rho _{ee}$ averaged over all the slices. Left plotted for a low excitation regime and three lines plotted separately for different excitations on the right hand side. This quantity is the actual observable in an experiment, which is also called the $4\pi $ scattered light\relax }{figure.caption.15}{}}
\newlabel{fig:summed_rhoee@cref}{{[figure][8][4]4.8}{[1][25][]26}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.9}{\ignorespaces The $\rho _{ee}$ is plotted as a function of slices and time for three different pulse areas, which correspond to the three lines plotted in \Cref  {fig:summed_rhoee}.\relax }}{26}{figure.caption.16}\protected@file@percent }
\newlabel{fig:threeblock_rhoee}{{4.9}{26}{The $\rho _{ee}$ is plotted as a function of slices and time for three different pulse areas, which correspond to the three lines plotted in \Cref {fig:summed_rhoee}.\relax }{figure.caption.16}{}}
\newlabel{fig:threeblock_rhoee@cref}{{[figure][9][4]4.9}{[1][25][]26}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.10}{\ignorespaces Ratio of coherent to incoherent light, $I_\mathrm  {coh}/ I_\mathrm  {inc}$, where the coherent light is $|\Omega |^2$ and the incoherent light is calculated as the emitted coherent light from every slice averaged.\relax }}{27}{figure.caption.17}\protected@file@percent }
\newlabel{fig:Actual_cohinc_ratio}{{4.10}{27}{Ratio of coherent to incoherent light, $I_\mathrm {coh}/ I_\mathrm {inc}$, where the coherent light is $|\Omega |^2$ and the incoherent light is calculated as the emitted coherent light from every slice averaged.\relax }{figure.caption.17}{}}
\newlabel{fig:Actual_cohinc_ratio@cref}{{[figure][10][4]4.10}{[1][25][]27}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.11}{\ignorespaces $|\Omega |^2$ as a function of time and excitation. Main result of the thesis. The time shift can be seen until population inversion and exactly by inversion the beats shift extremely and connect to the next beats. A transition can be observed around population inversion between the next and former Bessel beats. \relax }}{28}{figure.caption.18}\protected@file@percent }
\newlabel{fig:Omega_highexc}{{4.11}{28}{$|\Omega |^2$ as a function of time and excitation. Main result of the thesis. The time shift can be seen until population inversion and exactly by inversion the beats shift extremely and connect to the next beats. A transition can be observed around population inversion between the next and former Bessel beats. \relax }{figure.caption.18}{}}
\newlabel{fig:Omega_highexc@cref}{{[figure][11][4]4.11}{[1][27][]28}}
